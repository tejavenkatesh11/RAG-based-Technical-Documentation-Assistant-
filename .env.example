# ====== Required ======
GROQ_API_KEY=your_groq_key_here

# ====== Postgres ======
# Option A — set the full DSN:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rag_assistant
#
# Option B — set split variables (used if DATABASE_URL is empty):
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_assistant

# ====== Groq models (defaults) ======
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# ====== Vector store ======
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=tech_docs

# ====== Embeddings (local, no API key) ======
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ====== Retrieval / workflow ======
TOP_K=4
MAX_RETRIES=2

# ====== Logging ======
LOG_LEVEL=INFO
